DATABASE_URL=postgresql://user:password@localhost:5432/enterprise_db
DATABASE_REPLICA_URL=postgresql://user:password@localhost:5432/enterprise_db

# Redis - single node
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Redis - cluster mode (comma-separated host:port pairs, overrides single node if set)
REDIS_CLUSTER_NODES=

# Cache TTL in seconds (default: 300 = 5 minutes)
CACHE_TTL_SECONDS=300

JWT_ACCESS_SECRET=your-access-secret
JWT_REFRESH_SECRET=your-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
PORT=3000
NODE_ENV=development
