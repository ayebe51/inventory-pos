  id          String   @id @default(uuid()) @db.Uuid
  user_id     String   @db.Uuid
  action      String   @db.VarChar(50)
  entity_type String   @db.VarChar(100)
  entity_id   String   @db.Uuid
  data_before Json?
  data_after  Json?
  ip_address  String?  @db.VarChar(45)
  user_agent  String?  @db.VarChar(500)
  created_at  DateTime @default(now())

  // NO updated_at, NO deleted_at - immutable!
  user User @relation(fields: [user_id], references: [id])

  @@index([entity_type, entity_id])
  @@index([user_id, created_at(sort: Desc)])
  @@map("audit_logs")
}

model ApprovalRequest {
  id              String   @id @default(uuid()) @db.Uuid
  document_type   String   @db.VarChar(50)
  document_id     String   @db.Uuid
  document_number String   @db.VarChar(50)
  amount          Decimal? @db.Decimal(18, 2)
  approval_level  Int
  status          String   @default("PENDING") @db.VarChar(20)
  submitted_by    String   @db.Uuid
  submitted_at    DateTime
  notes           String?  @db.Text
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  submitted_by_user User                  @relation(fields: [submitted_by], references: [id])
  steps             ApprovalRequestStep[]

  @@map("approval_requests")
}

model ApprovalRequestStep {
  id          String    @id @default(uuid()) @db.Uuid
  request_id  String    @db.Uuid
  step_number Int
  approver_id String    @db.Uuid
  status      String    @default("PENDING") @db.VarChar(20)
  decision_at DateTime?
  notes       String?   @db.Text
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  approval_request ApprovalRequest @relation(fields: [request_id], references: [id])
  approver         User            @relation(fields: [approver_id], references: [id])

  @@map("approval_request_steps")
}
